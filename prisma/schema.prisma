// prisma/schema.prisma

generator client {
  provider = "prisma-client-js" // O provider correto é prisma-client-js
  // output é opcional. Se remover, o Prisma salva em node_modules/@prisma/client (padrão)
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id    Int     @id @default(autoincrement())
  nome String
  email String  @unique
  senha String
  perfil String // A - Admin, U - Usuário
  dataCadastro DateTime @default(now())
}