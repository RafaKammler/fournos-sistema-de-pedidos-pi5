// prisma/schema.prisma
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Perfil {
  ADMIN
  USUARIO
  GERENTE
}

enum TipoNotificacao {
  AVISO
  INFORMATIVA
}

enum StatusNotificacao {
  NAO_LIDA
  LIDA
}

enum StatusPedido {
  PENDENTE
  PREPARANDO
  PRONTO
  FINALIZADO
  CANCELADO
}

enum CategoriaEstabelecimento {
  LANCHES
  REFEICOES
  SALGADOS
  DOCES
  BEBIDAS
  SAUDAVEL
}

model Usuario {
  id           Int           @id @default(autoincrement())
  nome         String
  email        String        @unique
  senha        String
  perfil       Perfil
  dataCadastro DateTime      @default(now())
  gerente      Gerente?
  pedidos      Pedido[]
  notificacoes Notificacao[]
}

model Gerente {
  id               Int               @id @default(autoincrement())
  usuarioId        Int               @unique
  usuario          Usuario           @relation(fields: [usuarioId], references: [id])
  estabelecimentos Estabelecimento[]
  dataCadastro     DateTime          @default(now())
}

model Estabelecimento {
  id            Int      @id @default(autoincrement())
  nome          String
  descricao     String
  cnpj          String   @unique
  telefone      String
  caminhoImagem String
  cep           String
  dataCadastro  DateTime @default(now())
  gerenteId     Int?
  gerente       Gerente? @relation(fields: [gerenteId], references: [id], onDelete: SetNull)

  produtos     Produto[]
  notificacoes Notificacao[]
  complementos Complemento[]
  pedidos      Pedido[]

  categoria CategoriaEstabelecimento @default(LANCHES)
}

model Produto {
  id                Int                  @id @default(autoincrement())
  nome              String
  descricao         String
  preco             Float
  caminhoImagem     String?
  disponivel        Boolean              @default(true)
  estabelecimentoId Int
  estabelecimento   Estabelecimento      @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)
  dataCadastro      DateTime             @default(now())
  complementos      ProdutoComplemento[]
  itensPedido       ItemPedido[]
}

model Complemento {
  id                Int                  @id @default(autoincrement())
  nome              String
  preco             Float
  estabelecimentoId Int
  estabelecimento   Estabelecimento      @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)
  produtos          ProdutoComplemento[]
  dataCadastro      DateTime             @default(now())
}

model ProdutoComplemento {
  produtoId     Int
  complementoId Int
  produto       Produto     @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  complemento   Complemento @relation(fields: [complementoId], references: [id], onDelete: Cascade)

  @@id([produtoId, complementoId])
}

model Notificacao {
  id                Int               @id @default(autoincrement())
  titulo            String
  mensagem          String
  tipo              TipoNotificacao   @default(INFORMATIVA)
  status            StatusNotificacao @default(NAO_LIDA)
  usuarioId         Int?
  usuario           Usuario?          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  estabelecimentoId Int?
  estabelecimento   Estabelecimento?  @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)
  dataCriacao       DateTime          @default(now())
}

model Pedido {
  id                Int             @id @default(autoincrement())
  total             Float
  status            StatusPedido    @default(PENDENTE)
  usuarioId         Int
  usuario           Usuario         @relation(fields: [usuarioId], references: [id])
  estabelecimentoId Int
  estabelecimento   Estabelecimento @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)

  dataPedido DateTime     @default(now())
  itens      ItemPedido[]
}

model ItemPedido {
  id         Int     @id @default(autoincrement())
  quantidade Int
  precoUn    Float
  pedidoId   Int
  pedido     Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId  Int
  produto    Produto @relation(fields: [produtoId], references: [id])
}
