// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Perfil {
  ADMIN
  USUARIO
  GERENTE
}

enum TipoNotificacao {
  AVISO
  INFORMATIVA
}

enum StatusNotificacao {
  NAO_LIDA
  LIDA
}

model Usuario {
  id          Int       @id @default(autoincrement())
  nome        String
  email       String    @unique
  senha       String
  perfil      Perfil
  dataCadastro DateTime @default(now())
  gerente     Gerente?
}

model Gerente {
  id               Int             @id @default(autoincrement())
  usuarioId        Int             @unique
  usuario          Usuario         @relation(fields: [usuarioId], references: [id])
  estabelecimentoId Int?
  estabelecimento  Estabelecimento? @relation(fields: [estabelecimentoId], references: [id])
  dataCadastro     DateTime        @default(now())
}

model Estabelecimento {
  id            Int           @id @default(autoincrement())
  nome          String
  descricao     String
  cnpj          String        @unique
  telefone      String
  caminhoImagem String
  cep           String
  dataCadastro  DateTime      @default(now())
  gerentes      Gerente[]
  produtos      Produto[]
  notificacoes  Notificacao[]
}

model Produto {
  id                Int             @id @default(autoincrement())
  nome              String
  descricao         String
  preco             Float
  caminhoImagem     String?
  disponivel        Boolean         @default(true)
  estabelecimentoId Int
  estabelecimento   Estabelecimento @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)
  dataCadastro      DateTime        @default(now())
}

model Notificacao {
  id                Int               @id @default(autoincrement())
  titulo            String
  mensagem          String
  tipo              TipoNotificacao   @default(INFORMATIVA)
  status            StatusNotificacao @default(NAO_LIDA)
  estabelecimentoId Int
  estabelecimento   Estabelecimento   @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)
  dataCriacao       DateTime          @default(now())
}